@startuml

skinparam packageStyle rectangle
skinparam shadowing false

package "Layer 1: High-Level Control" {
    [Planificador\n(Manager)] as Planner
}

package "Layer 2: Cognitive / Autonomous Modules" {
    [Navegación] as Navigation
    [Percepción] as Perception
    [Interacción Humano-Robot] as HRI
    [Manejo de Datos] as Data
}

package "Layer 3: Sensor Interface (Streaming HAL)" {
    [Sensor Interface\n(Publish/Subscribe)] as Sensors
}

package "Layer 4: Actuation" {
    [Movimiento y Manipulación] as Motion
}

package "Hardware" {
    [Camera]
    [Microphone]
    [Ultrasonic Sensor]
    [Motors & Servos]
}

' Relaciones 

Planner -[hidden]-> Navigation
Navigation -[hidden]-> Sensors
Sensors -[hidden]-> Motion
Motion -[hidden]-> Camera

"Layer 1: High-Level Control" --> "Layer 2: Cognitive / Autonomous Modules" : objetivos/queries/órdenes
' Planner --> Navigation : goals

' Planner --> Perception : goals
' Planner --> HRI : goals
' Planner --> Data : queries
' Planner --> Motion : commands

' Modules interacting internally
Navigation --> Data : leer/escribir
Perception --> Data : leer/escribir
HRI --> Data : leer/escribir
Motion --> Data : leer

' Sensor streaming (publish/subscribe)
"Layer 3: Sensor Interface (Streaming HAL)" --> "Layer 2: Cognitive / Autonomous Modules" : sensor data streams
' Sensors --> Navigation : distance stream
' Sensors --> Perception : camera stream
' Sensors --> HRI : audio stream
Sensors --> Motion : distance stream

"Layer 2: Cognitive / Autonomous Modules" --> "Layer 3: Sensor Interface (Streaming HAL)" : subscribe to streams

' Navigation --> Sensors : subscribe
' Perception --> Sensors : subscribe
' HRI --> Sensors : subscribe
' Motion --> Sensors : subscribe

' Hardware connections
"Layer 3: Sensor Interface (Streaming HAL)" --> "Hardware" : leer
' Sensors --> Camera
' Sensors --> Microphone
' Sensors --> "Ultrasonic Sensor"

Motion --> "Motors & Servos" : controlar

@enduml